# Application
PROJECT_NAME="GS Pro Cleaning Services API"
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security — generate a strong secret for production
SECRET_KEY=change-me-to-a-long-random-string

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/gspro_cleaning

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET=

# SMTP / transactional email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=GS Pro Cleaning Services
SMTP_USE_TLS=true
